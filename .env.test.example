# 테스트 EC2 의 /home/ubuntu/meeteam/.env 로 복사해서 실제 값으로 채우세요.
# (이 example 파일만 git 에 올리고, 실제 .env 는 절대 커밋 금지)

# --- DB (compose-test.yml 의 mysql 컨테이너를 가리킴) ---
# host 는 compose 서비스명 'mysql', DB명은 아래 MYSQL_DATABASE 와 동일해야 함
DATASOURCE_URL=jdbc:mysql://mysql:3306/meeteam_test?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DATASOURCE_USERNAME=meeteam
DATASOURCE_PASSWORD=change-me-app-pw

# --- MySQL 컨테이너 초기화용 (위 DATASOURCE 와 값 일치시킬 것) ---
MYSQL_ROOT_PASSWORD=change-me-root-pw
MYSQL_DATABASE=meeteam_test
MYSQL_USER=meeteam
MYSQL_PASSWORD=change-me-app-pw

# --- JWT (운영과 다른 키 사용 권장) ---
JWT_SECRET_KEY=change-me-test-jwt-secret-at-least-32-bytes

# --- AWS / S3 (테스트 전용 버킷 권장) ---
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_REGION=ap-northeast-2
S3_BUCKET=meeteam-test-bucket

# --- 쿠키 (HTTP 직접 접속 기본값). HTTPS 테스트 도메인 붙이면 아래 주석 참고 ---
# COOKIE_DOMAIN=.test.meeteam.alom-sejong.com
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=None